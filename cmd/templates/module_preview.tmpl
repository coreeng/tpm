<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{.Title}}</title>
<style>
:root { color-scheme: light; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; color: #202124; background: #f6f7f9; }
body { margin: 0; }
main { max-width: 1180px; margin: 0 auto; padding: 32px 20px; }
header { margin-bottom: 24px; }
h1 { font-size: 34px; line-height: 1.15; margin: 0; }
h2 { font-size: 22px; margin: 0; }
h3 { font-size: 18px; margin: 0; }
p, pre { line-height: 1.55; }
pre { white-space: pre-wrap; font: inherit; margin: 0; }
.heading-row { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; margin-bottom: 8px; }
.source-badge { display: inline-flex; align-items: center; max-width: 100%; border: 1px solid #c6ccd6; border-radius: 999px; background: #f8fafc; color: #5f6368; padding: 2px 8px; font-size: 11px; font-weight: 700; line-height: 1.45; white-space: nowrap; text-transform: none; letter-spacing: 0; }
.source-line { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; color: #5f6368; font-size: 12px; font-weight: 700; margin-bottom: 6px; text-transform: uppercase; }
.field { margin-top: 12px; }
.field:first-child { margin-top: 0; }
.module-meta { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; color: #5f6368; font-size: 13px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; margin: 8px 0; }
.layout { display: grid; grid-template-columns: 320px 1fr; gap: 20px; align-items: start; }
.panel { background: #fff; border: 1px solid #d8dde6; border-radius: 8px; padding: 20px; }
.chapter-list { display: grid; gap: 10px; }
.toc-entry { border: 1px solid #c6ccd6; border-radius: 8px; background: #fff; overflow: hidden; }
.toc-entry.active { border-color: #1a73e8; box-shadow: 0 0 0 1px #1a73e8 inset; }
button { border: 0; background: transparent; cursor: pointer; font: inherit; }
.chapter-list button { width: 100%; text-align: left; display: grid; grid-template-columns: 34px 1fr; gap: 10px; align-items: start; padding: 12px; }
.chapter-list button:hover { background: #f6f9ff; }
.toc-number { color: #5f6368; font-variant-numeric: tabular-nums; font-weight: 700; }
.toc-title { display: block; font-weight: 700; }
.toc-meta { display: block; color: #5f6368; font-size: 13px; margin-top: 3px; }
.toc-sections { display: none; border-top: 1px solid #d8dde6; background: #f8fafc; padding: 8px 10px 10px 56px; }
.toc-entry.active .toc-sections { display: grid; gap: 6px; }
.toc-sections a { color: #3c4043; text-decoration: none; font-size: 14px; line-height: 1.35; }
.toc-sections a:hover { color: #1a73e8; text-decoration: underline; }
.content-panel { padding: 0; overflow: hidden; }
.chapter-hero { border-bottom: 1px solid #d8dde6; background: #f8fafc; padding: 22px 24px; }
.chapter-kicker, .section-kicker { color: #5f6368; font-size: 12px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; }
.chapter-body { padding: 22px 24px 24px; }
.item { border-left: 4px solid #d8dde6; padding: 0 0 0 16px; margin-top: 22px; }
.item:first-child { margin-top: 0; }
.section-meta { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; color: #5f6368; font-size: 14px; margin: 8px 0; }
.quiz { border-left-color: #1a73e8; }
.muted { color: #5f6368; }
.hidden { display: none; }
.video { display: inline-block; margin-top: 8px; color: #1a73e8; text-decoration: none; }
.quiz-option { display: block; width: auto; min-width: 220px; margin: 8px 0; border: 1px solid #c6ccd6; border-radius: 6px; padding: 9px 11px; text-align: left; cursor: default; }
@media (max-width: 760px) { .layout { grid-template-columns: 1fr; } main { padding: 20px 14px; } }
</style>
</head>
<body>
<main>
<header>
<div class="heading-row"><h1>{{.Title}}</h1>{{if .Source}}<span class="source-badge" title="Source file">{{.Source}}</span>{{end}}</div>
<div class="module-meta"><span>{{.Level}}</span>{{if .Source}}<span class="source-badge" title="Source file">{{.Source}}</span>{{end}}</div>
{{if .Description}}<div class="field"><div class="source-line"><span>Description</span>{{if .DescriptionSource}}<span class="source-badge" title="Source file">{{.DescriptionSource}}</span>{{end}}</div><pre>{{.Description}}</pre></div>{{end}}
</header>
<section class="layout">
<nav class="panel">
<h2>Chapters</h2>
<div class="chapter-list">
{{range $i, $chapter := .Chapters}}
<div class="toc-entry{{if eq $i 0}} active{{end}}" data-entry="chapter-{{$i}}">
<button type="button" data-target="chapter-{{$i}}">
<span class="toc-number">{{add1 $i}}.</span>
<span>
<span class="toc-title">{{$chapter.Title}}</span>
<span class="toc-meta">{{len $chapter.Sections}} section{{if ne (len $chapter.Sections) 1}}s{{end}}</span>
</span>
</button>
{{if $chapter.Sections}}
<div class="toc-sections">
{{range $sectionIndex, $section := $chapter.Sections}}
<a href="#chapter-{{$i}}-section-{{$sectionIndex}}">{{add1 $sectionIndex}}. {{$section.Title}}</a>
{{end}}
</div>
{{end}}
</div>
{{end}}
</div>
</nav>
<article class="panel content-panel">
{{range $i, $chapter := .Chapters}}
<section id="chapter-{{$i}}" class="chapter-detail{{if ne $i 0}} hidden{{end}}">
<div class="chapter-hero">
<div class="chapter-kicker">Chapter {{add1 $i}}</div>
<div class="heading-row"><h2>{{add1 $i}}. {{$chapter.Title}}</h2>{{if $chapter.Source}}<span class="source-badge" title="Source file">{{$chapter.Source}}</span>{{end}}</div>
{{if $chapter.Description}}<div class="field"><div class="source-line"><span>Description</span>{{if $chapter.DescriptionSource}}<span class="source-badge" title="Source file">{{$chapter.DescriptionSource}}</span>{{end}}</div><pre>{{$chapter.Description}}</pre></div>{{end}}
{{if $chapter.BannerVideo}}<div class="field"><a class="video" href="{{$chapter.BannerVideo}}">Video link</a>{{if $chapter.Source}}<span class="source-badge" title="Source file">{{$chapter.Source}}</span>{{end}}</div>{{end}}
</div>
<div class="chapter-body">
{{range $sectionIndex, $section := $chapter.Sections}}
<div class="item" id="chapter-{{$i}}-section-{{$sectionIndex}}">
<div class="section-kicker">Section {{add1 $sectionIndex}}</div>
<div class="heading-row"><h3>{{$section.Title}}</h3>{{if $section.Source}}<span class="source-badge" title="Source file">{{$section.Source}}</span>{{end}}</div>
{{if $section.EstimatedDuration}}<div class="section-meta"><span>{{$section.EstimatedDuration}}</span>{{if $section.Source}}<span class="source-badge" title="Source file">{{$section.Source}}</span>{{end}}</div>{{end}}
{{if $section.Description}}<div class="field"><div class="source-line"><span>Description</span>{{if $section.DescriptionSource}}<span class="source-badge" title="Source file">{{$section.DescriptionSource}}</span>{{end}}</div><pre>{{$section.Description}}</pre></div>{{end}}
{{if $section.Video}}<div class="field"><a class="video" href="{{$section.Video}}">Video link</a>{{if $section.Source}}<span class="source-badge" title="Source file">{{$section.Source}}</span>{{end}}</div>{{end}}
</div>
{{end}}
{{range $lab := $chapter.Assessments}}
<div class="item">
<div class="heading-row"><h3>{{$lab.Title}}</h3>{{if $lab.Source}}<span class="source-badge" title="Source file">{{$lab.Source}}</span>{{end}}</div>
{{if $lab.TimeLimit}}<div class="section-meta"><span>{{$lab.TimeLimit}}</span>{{if $lab.Source}}<span class="source-badge" title="Source file">{{$lab.Source}}</span>{{end}}</div>{{end}}
{{if $lab.Description}}<div class="field"><div class="source-line"><span>Description</span>{{if $lab.DescriptionSource}}<span class="source-badge" title="Source file">{{$lab.DescriptionSource}}</span>{{end}}</div><pre>{{$lab.Description}}</pre></div>{{end}}
{{range $challenge := $lab.Challenges}}
<div class="field"><div class="heading-row"><h3>{{$challenge.Title}}</h3>{{if $challenge.Source}}<span class="source-badge" title="Source file">{{$challenge.Source}}</span>{{end}}</div></div>
{{if $challenge.Description}}<div class="field"><div class="source-line"><span>Description</span>{{if $challenge.DescriptionSource}}<span class="source-badge" title="Source file">{{$challenge.DescriptionSource}}</span>{{end}}</div><pre>{{$challenge.Description}}</pre></div>{{end}}
{{range $goalIndex, $goal := $challenge.Goals}}
<p><strong>{{add1 $goalIndex}}. {{$goal.Title}}</strong> {{if $goal.Source}}<span class="source-badge" title="Source file">{{$goal.Source}}</span>{{end}}<br>{{$goal.Description}}</p>
{{end}}
{{if $challenge.SuccessMessage}}<div class="field"><div class="source-line"><span>Success message</span>{{if $challenge.SuccessMessageSource}}<span class="source-badge" title="Source file">{{$challenge.SuccessMessageSource}}</span>{{end}}</div><pre>{{$challenge.SuccessMessage}}</pre></div>{{end}}
{{end}}
</div>
{{end}}
{{range $quiz := $chapter.MultipleChoiceAssessments}}
<div class="item quiz">
<div class="section-kicker">Quiz</div>
<div class="heading-row"><h3>{{$quiz.Title}}</h3>{{if $quiz.Source}}<span class="source-badge" title="Source file">{{$quiz.Source}}</span>{{end}}</div>
{{if $quiz.Description}}<p>{{$quiz.Description}} {{if $quiz.Source}}<span class="source-badge" title="Source file">{{$quiz.Source}}</span>{{end}}</p>{{end}}
{{range $question := $quiz.Questions}}
<p><strong>{{$question.Text}}</strong> {{if $question.Source}}<span class="source-badge" title="Source file">{{$question.Source}}</span>{{end}}</p>
{{range $option := $question.Options}}
<button class="quiz-option" type="button">{{$option.Text}} {{if $option.Source}}<span class="source-badge" title="Source file">{{$option.Source}}</span>{{end}}</button>
{{end}}
{{end}}
</div>
{{end}}
</div>
</section>
{{end}}
</article>
</section>
</main>
<script>
const buttons = [...document.querySelectorAll('button[data-target]')];
const entries = [...document.querySelectorAll('.toc-entry')];
const panels = [...document.querySelectorAll('.chapter-detail')];
function showChapter(target) {
  entries.forEach((entry) => entry.classList.toggle('active', entry.dataset.entry === target));
  panels.forEach((panel) => panel.classList.toggle('hidden', panel.id !== target));
}
buttons.forEach((button) => button.addEventListener('click', () => showChapter(button.dataset.target)));
</script>
</body>
</html>
